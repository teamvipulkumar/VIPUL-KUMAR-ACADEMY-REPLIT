modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=26209 BASE_PATH=/ pnpm --filter @workspace/course-platform run dev"
waitForPort = 26209

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8084
externalPort = 5173

[[ports]]
localPort = 8085
externalPort = 6800

[[ports]]
localPort = 8086
externalPort = 8008

[[ports]]
localPort = 8087
externalPort = 8081

[[ports]]
localPort = 26209
externalPort = 3000

[[ports]]
localPort = 26210
externalPort = 3002

[[ports]]
localPort = 26211
externalPort = 4200

[[ports]]
localPort = 26212
externalPort = 5000

[[ports]]
localPort = 26213
externalPort = 6000

[[ports]]
localPort = 26214
externalPort = 8000

[[ports]]
localPort = 26215
externalPort = 8099

[nix]
channel = "stable-25_05"
